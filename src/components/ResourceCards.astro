---
import { Icon } from 'astro-icon/components';

// Single source of truth for the resource overview shown on the home page and
// the Resources page. Each card links to its detail page.
const areas = [
  {
    title: 'GPU & LLM Cluster',
    href: '/gpu-cluster',
    icon: 'tabler:cpu',
    description:
      'Train and fine-tune models, run interactive GPU notebooks, and call a hosted OpenAI-compatible LLM and embedding API — built for Digital Humanities, not generic HPC.',
  },
  {
    title: 'Digitization',
    href: '/digitization',
    icon: 'tabler:scan',
    description:
      'Multispectral imaging (XpeCAM, MISHA), a scanning robot for fragile loose-leaf collections, and borrowable inference GPUs — available on request.',
  },
  {
    title: 'SaaS / IaaS & storage',
    href: '/saas',
    icon: 'tabler:server',
    description:
      'Database-as-a-service, dev/test VMs and CI runners, plus short and mid-term project storage — a development-first complement to your own institution.',
  },
  {
    title: 'Open Source Software',
    href: '/software',
    icon: 'tabler:code',
    description:
      'Three DH tools improved through DHInfra investment — QLever, liiive.now and Zellij. Usable on our cluster and elsewhere.',
  },
];
---

<div class="grid gap-6 sm:grid-cols-2">
  {
    areas.map((a) => (
      <a
        href={a.href}
        class="group flex flex-col rounded-lg border border-gray-200 bg-white p-6 transition hover:border-primary hover:shadow-sm dark:border-slate-700 dark:bg-slate-900"
      >
        <Icon name={a.icon} class="h-7 w-7 text-primary" />
        <h3 class="mt-3 text-lg font-bold group-hover:text-primary">{a.title}</h3>
        <p class="mt-2 text-sm text-muted">{a.description}</p>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary">
          Read more
          <Icon name="tabler:chevron-right" class="h-4 w-4" />
        </span>
      </a>
    ))
  }
</div>
