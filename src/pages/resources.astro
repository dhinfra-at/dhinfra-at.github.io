---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ResourceCards from '~/components/ResourceCards.astro';

const metadata = {
  title: 'Resources',
};

const partners = ['KFUG', 'PLUS', 'UWK', 'UniAK', 'LFUI', 'TUW', 'ÖNB', 'ÖAW', 'UniVie'];
// '*' = core contributor, '+' = supporting contributor
const matrix = [
  { area: 'Digitization', cells: ['+', '', '', '', '*', '*', '', '', ''] },
  { area: 'GPU / ML', cells: ['*', '+', '*', '+', '+', '+', '+', '+', ''] },
  { area: 'SaaS / IaaS & storage', cells: ['', '*', '+', '+', '', '', '', '', ''] },
  { area: 'Software', cells: ['*', '+', '', '+', '+', '', '+', '+', '+'] },
];
const mark = (c: string) => (c === '*' ? '★' : c === '+' ? '✓' : '');
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Resources"
    title='Digital Humanities infrastructure<br class="hidden sm:inline" /> across Austria'
    subtitle="DHInfra.at partners offer shared infrastructure in four areas. This is the overview — open each one for what it is, how it is used, and who to contact."
  />

  <!-- Overview cards -->
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 md:py-16">
    <ResourceCards />
  </section>

  <!-- Partner contribution matrix -->
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 md:py-16">
    <h2 class="text-2xl font-bold">Partner contributions</h2>
    <p class="mt-3 text-muted">
      Who contributes to each area. <span class="font-semibold">★</span> core contributor ·
      <span class="font-semibold">✓</span> supporting contributor. See <a
        class="text-primary hover:underline"
        href="/partners">Partners</a
      > for contacts.
    </p>
    <div class="mt-6 overflow-x-auto">
      <table class="w-full border-collapse text-center text-sm">
        <thead>
          <tr class="border-b border-gray-200 dark:border-slate-700">
            <th class="px-2 py-2 text-left">Area</th>
            {partners.map((p) => <th class="px-2 py-2 font-semibold">{p}</th>)}
          </tr>
        </thead>
        <tbody>
          {
            matrix.map((row) => (
              <tr class="border-b border-gray-100 dark:border-slate-800">
                <td class="px-2 py-2 text-left font-medium">{row.area}</td>
                {row.cells.map((c) => (
                  <td class="px-2 py-2 text-primary">{mark(c)}</td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</Layout>
