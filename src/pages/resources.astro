---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ResourceCards from '~/components/ResourceCards.astro';
import { facilities, facilityGroups } from '~/data/facilities';

const metadata = {
  title: 'Resources',
};

const partners = ['KFUG', 'PLUS', 'UWK', 'UniAK', 'LFUI', 'TUW', 'ÖNB', 'ÖAW', 'UniVie'];
// '*' = core contributor, '+' = supporting contributor
const matrix = [
  { area: 'Digitization', cells: ['+', '', '', '', '*', '*', '', '', ''] },
  { area: 'GPU / ML', cells: ['*', '+', '*', '+', '+', '+', '+', '+', ''] },
  { area: 'SaaS / IaaS & storage', cells: ['', '*', '+', '+', '', '', '', '', ''] },
  { area: 'Software', cells: ['*', '+', '', '+', '+', '', '+', '+', '+'] },
];
const mark = (c: string) => (c === '*' ? '★' : c === '+' ? '✓' : '');
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Resources"
    title='Digital Humanities infrastructure<br class="hidden sm:inline" /> across Austria'
    subtitle="DHInfra.at partners offer shared infrastructure in four areas. This is the overview — open each one for what it is, how it is used, and who to contact."
  />

  <!-- Overview cards -->
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 md:py-16">
    <ResourceCards />
  </section>

  <!-- Partner contribution matrix -->
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 md:py-16">
    <h2 class="text-2xl font-bold">Partner contributions</h2>
    <p class="mt-3 text-muted">
      Who contributes to each area. <span class="font-semibold">★</span> core contributor ·
      <span class="font-semibold">✓</span> supporting contributor. See <a
        class="text-primary hover:underline"
        href="/partners">Partners</a
      > for contacts.
    </p>
    <div class="mt-6 overflow-x-auto">
      <table class="w-full border-collapse text-center text-sm">
        <thead>
          <tr class="border-b border-gray-200 dark:border-slate-700">
            <th class="px-2 py-2 text-left">Area</th>
            {partners.map((p) => <th class="px-2 py-2 font-semibold">{p}</th>)}
          </tr>
        </thead>
        <tbody>
          {
            matrix.map((row) => (
              <tr class="border-b border-gray-100 dark:border-slate-800">
                <td class="px-2 py-2 text-left font-medium">{row.area}</td>
                {row.cells.map((c) => (
                  <td class="px-2 py-2 text-primary">{mark(c)}</td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <!-- Registered research infrastructure (national FI DB) -->
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 md:py-16">
    <h2 class="text-2xl font-bold">Registered research infrastructure</h2>
    <p class="mt-3 text-muted">
      The hardware and facilities behind DHInfra.at are registered in the national research-infrastructure database (FI
      DB) of the BMBWF, across the participating institutions. Each entry names its contact person. Some entries are
      still being applied for.
    </p>
    {
      facilityGroups.map(({ group, heading }) => {
        const items = facilities.filter((f) => f.group === group);
        if (items.length === 0) return null;
        return (
          <div class="mt-8">
            <h3 class="text-lg font-semibold">{heading}</h3>
            <div class="mt-4 overflow-x-auto">
              <table class="w-full border-collapse text-sm">
                <thead>
                  <tr class="border-b border-gray-200 dark:border-slate-700">
                    <th class="py-2 pr-4 text-left">Facility</th>
                    <th class="py-2 pr-4 text-left">Institution</th>
                    <th class="py-2 pr-4 text-left">FI DB</th>
                  </tr>
                </thead>
                <tbody>
                  {items.map((f) => (
                    <tr class="border-b border-gray-100 dark:border-slate-800">
                      <td class="py-3 pr-4 align-top">
                        {f.name}
                        {f.desc && <div class="text-xs text-muted">{f.desc}</div>}
                      </td>
                      <td class="py-3 pr-4 align-top">{f.institution}</td>
                      <td class="py-3 pr-4 align-top">
                        {f.link ? (
                          <a class="text-primary hover:underline" href={f.link} target="_blank" rel="noopener noreferrer">
                            Entry
                          </a>
                        ) : (
                          <span class="text-muted">requested</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        );
      })
    }
  </section>
</Layout>
