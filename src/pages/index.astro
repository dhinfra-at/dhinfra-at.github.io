---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import ResourceCards from '~/components/ResourceCards.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'DHInfra.at — Digital Humanities Infrastructure in Austria',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero ************************** -->

  <Hero
    actions={[
      { variant: 'primary', text: 'Explore resources', href: '/resources' },
      { text: 'Open for collaboration', href: '/contact' },
    ]}
  >
    <Fragment slot="title">
      Shared infrastructure for<br class="hidden sm:inline" /> Digital Humanities in Austria
    </Fragment>

    <Fragment slot="subtitle">
      We pool <span class="whitespace-nowrap">compute</span>,
      <span class="whitespace-nowrap">development services</span>,
      <span class="whitespace-nowrap">digitization</span>, and
      <span class="whitespace-nowrap">open-source software</span> across Austrian institutions &mdash; so DH projects
      that lack resources or skills can still get the job done. A
      <span class="font-semibold">CLARIAH-AT</span> initiative.
    </Fragment>
  </Hero>

  <!-- Positioning note ************* -->

  <Note
    title="What we do:"
    description="More compute, easier access, and better support for digital humanities — democratizing infrastructure for all."
  />

  <!-- Resource compartments ******* -->

  <section id="resources" class="mx-auto max-w-5xl px-4 py-12 sm:px-6 md:py-16">
    <div class="mb-8 text-center">
      <p class="text-base font-semibold uppercase tracking-wide text-primary">Resources</p>
      <h2 class="text-3xl font-bold tracking-tight dark:text-white sm:text-4xl">What DHInfra.at offers</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-muted">
        Distinct infrastructure parts, contributed by partners across Austria. Open each one for details and contacts.
      </p>
    </div>
    <ResourceCards />
  </section>

  <!-- Project stats *************** -->

  <Stats
    title="The DHInfra.at consortium"
    stats={[
      { title: 'Institutions', amount: '9' },
      { title: 'Working groups', amount: '4' },
      { title: 'Members', amount: '50+' },
      { title: 'Associates', amount: '100+' },
    ]}
  />

  <!-- Latest use cases *********** -->

  <BlogLatestPosts
    title="Use cases & news"
    information={`Real projects on our infrastructure, announcements, and reports from across the consortium.`}
  />

  <!-- Collaboration CTA ********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get in touch',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">Lacking resources or skills for your DH project?</Fragment>

    <Fragment slot="subtitle">
      We are open to project collaborations and happy to help in joint projects. Contact us and we will try to find the
      best solution for your idea.
    </Fragment>
  </CallToAction>
</Layout>
